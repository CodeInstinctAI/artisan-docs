{
    "name": "code-instinct/artisan-docs",
    "description": "Automatically generate documentation for all Artisan commands in a Laravel application.",
    "keywords": ["laravel", "artisan", "documentation", "commands", "docs"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Code Instinct",
            "email": "info@codeinstinct.nl"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "CodeInstinct\\ArtisanDocs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CodeInstinct\\ArtisanDocs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CodeInstinct\\ArtisanDocs\\ArtisanDocsServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.1"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
